# Vídeos e áudio brutos — não versionar (pesados)
downloads/
audio/

# Estado do RAG (regenerável)
.rag/

# Sessões / cookies (credenciais — NUNCA versionar)
.instaloader
*.session
session-*
*cookies*.txt
*.cookies

# Python
.venv/
__pycache__/
*.pyc

# App (Next.js) — build/deps
app/node_modules/
app/.next/
app/out/
app/.turbo/

# Manifests por conta (.db + .json export) — estado local/pessoal, NÃO versionar
/manifests/*
!/manifests/.gitkeep

# Manifest legado da raiz (estado pessoal) — NÃO versionar
/manifest.json

# Notas geradas (pessoais, específicas do seu acervo/uso) — NÃO versionar
/notes/*
!/notes/.gitkeep

# OCR language data (pesado, re-baixável)
*.traineddata

# Volume de dados do Docker (downloads/manifests/cookies montados aqui)
data/

# Cache de build do TypeScript
*.tsbuildinfo

# Claude Code — configs locais da máquina (permissões)
.claude/settings.local.json
