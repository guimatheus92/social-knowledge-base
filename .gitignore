# Raw videos and audio — not versioned (heavy)
downloads/
audio/

# RAG state (regenerable)
.rag/

# Sessions / cookies (credentials — NEVER version)
.instaloader
*.session
session-*
*cookies*.txt
*.cookies

# Python
.venv/
__pycache__/
*.pyc

# App (Next.js) — build/deps
app/node_modules/
app/.next/
app/out/
app/.turbo/

# Per-account manifests (.db + .json export) — local/personal state, NOT versioned
/manifests/*
!/manifests/.gitkeep

# Legacy root manifest (personal state) — NOT versioned
/manifest.json

# Generated notes (personal, specific to your collection/usage) — NOT versioned
/notes/*
!/notes/.gitkeep

# OCR language data (heavy, re-downloadable)
*.traineddata

# Docker data volume (downloads/manifests/cookies mounted here)
data/

# TypeScript build cache
*.tsbuildinfo

# Claude Code — machine-local config (permissions)
.claude/settings.local.json

# Design mockups (temporary — keep local while the UI isn't redone)
/design-mockups/
